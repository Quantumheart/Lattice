{
  "app-id": "io.github.quantumheart.kohera",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "kohera",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--filesystem=xdg-run/pipewire-0",
    "--device=all",
    "--filesystem=xdg-download",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.freedesktop.secrets",
    "--system-talk-name=org.freedesktop.NetworkManager"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "*.a",
    "*.la"
  ],
  "modules": [
    {
      "name": "libplacebo",
      "buildsystem": "meson",
      "config-opts": [
        "-Ddemos=false",
        "-Dvulkan=disabled",
        "-Dopengl=disabled",
        "-Dd3d11=disabled"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://code.videolan.org/videolan/libplacebo/-/archive/v7.349.0/libplacebo-v7.349.0.tar.gz",
          "sha256": "79120e685a1836344b51b13b6a5661622486a84e4d4a35f6c8d01679a20fbc86"
        }
      ]
    },
    {
      "name": "libass",
      "config-opts": [
        "--disable-static"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/libass/libass/releases/download/0.17.3/libass-0.17.3.tar.gz",
          "sha256": "da7c348deb6fa6c24507afab2dee7545ba5dd5bbf90a137bfe9e738f7df68537"
        }
      ]
    },
    {
      "name": "libmpv",
      "buildsystem": "meson",
      "config-opts": [
        "-Dlibmpv=true",
        "-Dcplayer=false",
        "-Dbuild-date=false",
        "-Dalsa=disabled",
        "-Dmanpage-build=disabled",
        "-Dgpl=false"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/mpv-player/mpv/archive/refs/tags/v0.39.0.tar.gz",
          "sha256": "2ca92437affb62c2b559b4419ea4785c70d023590500e8a52e95ea3ab4554683"
        }
      ]
    },
    {
      "name": "kohera",
      "buildsystem": "simple",
      "build-commands": [
        "cp -r bundle/ /app/kohera/",
        "mkdir -p /app/bin",
        "ln -s /app/kohera/kohera /app/bin/kohera",
        "install -Dm644 io.github.quantumheart.kohera.desktop /app/share/applications/io.github.quantumheart.kohera.desktop",
        "install -Dm644 io.github.quantumheart.kohera.metainfo.xml /app/share/metainfo/io.github.quantumheart.kohera.metainfo.xml",
        "install -Dm644 io.github.quantumheart.kohera.png /app/share/icons/hicolor/512x512/apps/io.github.quantumheart.kohera.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../build/linux/x64/release/bundle",
          "dest": "bundle"
        },
        {
          "type": "file",
          "path": "io.github.quantumheart.kohera.metainfo.xml"
        },
        {
          "type": "file",
          "path": "../linux/io.github.quantumheart.kohera.desktop"
        },
        {
          "type": "file",
          "path": "../macos/Runner/Assets.xcassets/AppIcon.appiconset/app_icon_512.png",
          "dest-filename": "io.github.quantumheart.kohera.png"
        }
      ]
    }
  ]
}
