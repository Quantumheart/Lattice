{
  "files.watcherExclude": {
    "**/.dart_tool/**": true,
    "**/.flutter-plugins*": true,
    "**/build/**": true,
    "**/.pub-cache/**": true,
    "**/*.mocks.dart": true,
    "**/.flatpak-builder/**": true,
    "**/flatpak/.flatpak-builder-build/**": true,
    "**/build-dir/**": true
  },
  "search.exclude": {
    "**/.dart_tool/**": true,
    "**/build/**": true,
    "**/.pub-cache/**": true,
    "**/pubspec.lock": true,
    "**/.flatpak-builder/**": true,
    "**/flatpak/.flatpak-builder-build/**": true,
    "**/build-dir/**": true
  },
  "files.exclude": {
    "**/.dart_tool": true,
    "**/build": true
  },
  "npm.exclude": [
    "**/.flatpak-builder/**",
    "**/flatpak/**"
  ]
}
